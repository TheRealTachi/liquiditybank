# =============================================================================
# Liquidity Bank — frontend env
# =============================================================================
#
# Copy to `.env` and fill in your values. Both vars must be set for the app
# to construct real transactions.

# Solana RPC endpoint. Use a paid endpoint (Helius, Triton, QuickNode) for
# anything beyond casual testing — the public mainnet-beta endpoint is rate-
# limited and tx broadcasts will sometimes drop.
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com

# The deployed Liquidity Bank program ID.
NEXT_PUBLIC_PROGRAM_ID=LiqsdMHNBjXJt5XHjRq7f4H8tDwcBu4yj2cuUv6MNYi

# Pinata JWT for pinning launch images + metadata JSON to IPFS. Pump.fun's
# indexer fetches the metadata URI from a public gateway, so we cannot serve
# it ourselves from /public/uploads (Vercel serverless FS is read-only and
# localhost is unreachable). Get a JWT at
# https://app.pinata.cloud/developers/api-keys with pinFileToIPFS +
# pinJSONToIPFS scopes.
PINATA_JWT=

# =============================================================================
# Local development (uncomment to override)
# =============================================================================
# NEXT_PUBLIC_SOLANA_RPC=http://127.0.0.1:8899
